# Firebase project whose ID tokens the API accepts (defaults to bridou-online).
# FIREBASE_PROJECT_ID=bridou-online

# Comma-separated list of allowed CORS origins. Set in production to lock the
# API to the real frontend; unset means local dev (any origin, so LAN phones work).
# WEB_ORIGINS=https://bridou.example.com

# Neon Postgres connection string (optional).
# Loaded automatically by `pnpm dev` / `pnpm start` via dotenv.
# When set, the server (a) writes finished games + the full DomainEvent stream
# for analytics AND (b) persists in-flight games so they survive a restart —
# a reconnecting player resumes exactly where they left off. When unset,
# everything lives in memory (fine for local play; lost on restart).
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/bridou?sslmode=require

# Apply schema once: pnpm --filter @bridou/server db:migrate
