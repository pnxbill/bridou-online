# Copy to .env.local to override (all values below are the built-in defaults).
# NEXT_PUBLIC_* vars are inlined at build time — restart `pnpm dev` / rebuild after changing.

# Realtime transport: "sse" (default) or "socketio" to switch back to sockets.
NEXT_PUBLIC_REALTIME_TRANSPORT=sse

# Game server base URL. Leave unset in local LAN testing so the browser uses
# the page hostname on :3001 (e.g. phone → http://192.168.0.6:3001).
# Set explicitly for production or when the game server is on another host.
# NEXT_PUBLIC_GAME_SERVER_URL=http://localhost:3001

# Voice chat TURN relay (optional). Unset = STUN only, which connects most
# home networks; add a relay if some players can't hear each other.
# NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=user
# NEXT_PUBLIC_TURN_CREDENTIAL=secret

# Firebase web config (public by design; override per environment if needed).
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAx_aEjr3dRD8T2DmfULuNBK3zYOTMGekE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=bridou-online.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=bridou-online
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=bridou-online.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=648671635109
NEXT_PUBLIC_FIREBASE_APP_ID=1:648671635109:web:dbfa0799df25f303e38f4c
